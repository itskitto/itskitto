---
interface NavItem {
  label: string
  href: string
  count?: number
}

interface Props {
  heading: string
  items: NavItem[]
}

const { heading, items } = Astro.props
const currentPath = Astro.url.pathname
---

<nav class="nav-group">
  <p class="nav-group__heading section-label">{heading}</p>
  <ul class="nav-group__list">
    {items.map(({ label, href, count }) => (
      <li>
        <a
          class="nav-group__link"
          href={href}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          <span>{label}</span>
          {count !== undefined && (
            <span class="nav-group__count">{String(count).padStart(2, '0')}</span>
          )}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .nav-group__heading {
    /* base styles via .section-label */
    margin-block-end: 0.375rem;
  }

  .nav-group__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .nav-group__link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    text-align: start;
    transition: color 0.1s;
  }

  .nav-group__link:hover {
    color: var(--color-text);
  }

  .nav-group__link[aria-current='page'] {
    color: var(--color-brand-text);
    font-weight: 600;
  }

  .nav-group__count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
