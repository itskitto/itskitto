---
import type { CollectionEntry } from 'astro:content'

interface Props {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props
const { title, description, status, type, stack, startDate } = project.data

const date = startDate
  .toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  .toUpperCase()
---

<article class="project-card">
  <header class="project-card__meta meta-row">
    <span class="project-card__type">TYPE: {type.toUpperCase()}</span>
    <time class="project-card__date" datetime={startDate.toISOString()}>{date}</time>
    <span class={`project-card__status project-card__status--${status}`}>
      {status === 'active' && <span class="project-card__dot" aria-hidden="true" />}
      {status.toUpperCase()}
    </span>
  </header>

  <h2 class="project-card__title" transition:name={`project-title-${project.id}`}>
    <a href={`/projects/${project.id}`}>{title}</a>
  </h2>

  <p class="project-card__description">{description}</p>

  <ul class="project-card__stack" aria-label="Tech stack">
    {stack.map((tech) => <li class="project-card__pill">{tech}</li>)}
  </ul>

  <hr class="project-card__divider" />

  <footer class="project-card__actions">
    <a class="btn btn--brand btn--sm" href={`/projects/${project.id}`}>View Project</a>
  </footer>
</article>

<style>
  .project-card {
    background: var(--color-surface);
    border: var(--border-thin) solid var(--color-border);
    border-radius: var(--border-radius);
    padding: var(--s1);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card {
      transition: background 0.15s, box-shadow 0.15s;
    }

    .project-card:hover {
      background: var(--color-surface);
      box-shadow: inset 3px 0 0 var(--color-brand);
    }
  }

  /* .project-card__meta base styles via .meta-row */

  .project-card__type {
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .project-card__date {
    color: var(--color-text-muted);
  }

  .project-card__status {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding-block: 0.2rem;
    padding-inline: 0.5rem;
    border-radius: var(--border-radius-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .project-card__status--active {
    background: var(--color-available-bg);
    color: var(--color-available);
  }

  .project-card__status--complete {
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: var(--border-thin) solid var(--color-border);
  }

  .project-card__status--archived {
    background: transparent;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .project-card__dot {
    position: relative;
    display: inline-block;
    inline-size: 6px;
    block-size: 6px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card__dot::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: var(--border-radius-full);
      background: currentColor;
      animation: dot-ping 2.5s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    }
  }

  .project-card__title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .project-card__title a {
    text-decoration: none;
    transition: color 0.1s;
  }

  .project-card__title a:hover { color: var(--color-brand); }

  .project-card__description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-inline-size: 60ch;
  }

  .project-card__stack {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .project-card__pill {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-bg);
    border: var(--border-thin) solid var(--color-border);
    padding-block: 0.2rem;
    padding-inline: 0.45rem;
    border-radius: var(--border-radius-sm);
    white-space: nowrap;
  }

  .project-card__divider {
    border: none;
    border-block-start: var(--border-thin) solid var(--color-border);
  }

  .project-card__actions {
    display: flex;
    align-items: center;
    gap: var(--s1);
  }

</style>
