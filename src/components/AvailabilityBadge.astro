---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="badge">
  <span class="badge__dot" aria-hidden="true"></span>
  {label}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding-block: 0.3rem;
    padding-inline: 0.75rem;
    border: var(--border-thin) solid var(--color-available-border);
    background-color: var(--color-available-bg);
    border-radius: var(--border-radius-full);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .badge__dot {
    position: relative;
    display: inline-block;
    inline-size: 0.45rem;
    block-size: 0.45rem;
    border-radius: var(--border-radius-full);
    background: var(--color-available);
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .badge__dot::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: var(--border-radius-full);
      background: var(--color-available);
      animation: dot-ping 2.5s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    }
  }
</style>
