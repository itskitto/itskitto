---
import { ClientRouter } from 'astro:transitions'
import Sidebar from '../components/Sidebar.astro'
import StatusBar from '../components/StatusBar.astro'
import type { SidebarConfig, StatusConfig } from '../types'
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  sidebar?: SidebarConfig
  status?: StatusConfig
}

const { title, description, sidebar, status } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" /></noscript>
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      if (localStorage.getItem('sidebar-collapsed') === 'true') {
        document.documentElement.classList.add('sidebar-collapsed')
      }
    </script>
  </head>
  <body>
    <Sidebar
      name={sidebar?.name ?? 'Your Name'}
      title={sidebar?.title ?? 'Your Title'}
      initials={sidebar?.initials ?? 'YN'}
      avatarSrc={sidebar?.avatarSrc}
      ctaLabel={sidebar?.cta?.label}
      ctaHref={sidebar?.cta?.href}
      ctaComingSoon={sidebar?.cta?.comingSoon}
      nav={sidebar?.nav ?? []}
      availability={sidebar?.availability}
    />
    <div class="sidebar-scrim" id="sidebar-scrim" aria-hidden="true"></div>

    <main class="main">
      <slot />
    </main>

    <StatusBar messages={status?.messages} interval={status?.interval} right={status?.right} />
  </body>
</html>

<style is:global>
  .main {
    margin-inline-start: var(--sidebar-width);
    min-block-size: 100vh;
    padding: var(--s2) var(--s3);
    padding-block-start: calc(var(--statusbar-height) + var(--s2));
    transition: margin-inline-start 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Suppress margin transition while a view transition is active to prevent
     the morphing title from being displaced as .main's left margin settles. */
  html:has(::view-transition) .main {
    transition: none;
  }

  @media (max-width: 48em) {
    .main {
      padding-inline: var(--s1);
      transition: none;
    }
  }
</style>
