---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import PostCard from '../../components/PostCard.astro'
import ContactCTA from '../../components/ContactCTA.astro'
import { SIDEBAR, STATUS_MESSAGES } from '../../config'
import { getNav } from '../../lib/nav'

const allPosts = await getCollection('posts', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
)

const posts = [...allPosts].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
)

const nav = await getNav()
---

<BaseLayout
  title="Posts — Nicholas Khrangtong"
  description="Writing on software engineering, systems design, and the craft of building things that work."
  sidebar={{
    ...SIDEBAR,
    nav,
  }}
  status={{ messages: STATUS_MESSAGES }}
>
  <Breadcrumb crumbs={[{ label: 'Index', href: '/' }, { label: 'Posts' }]} />

  <div class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
    <ContactCTA
      headline="Something on your mind?"
      label="Get in touch →"
      compact
    />
  </div>
</BaseLayout>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--s1);
    max-inline-size: 44rem;
    padding-block-start: var(--s1);
  }
</style>
