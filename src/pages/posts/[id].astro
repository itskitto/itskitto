---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import PostEnding from '../../components/PostEnding.tsx'
import { SIDEBAR, STATUS_MESSAGES } from '../../config'
import { getNav } from '../../lib/nav'

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)

const nav = await getNav()

const toc = headings.filter((h) => h.depth <= 3)

// Extract external links from the post body for the sidebar refs panel.
// Strip the explicit ## References section first to avoid duplication.
const bodyForRefs = (post.body ?? '').split('\n## References')[0]
const linkRegex = /\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g
const seenRefs = new Set<string>()
const refs: { href: string; label: string }[] = []

let refMatch: RegExpExecArray | null
while ((refMatch = linkRegex.exec(bodyForRefs)) !== null) {
  const href = refMatch[2]
  if (!seenRefs.has(href)) {
    seenRefs.add(href)
    let label = href
    try {
      const url = new URL(href)
      const parts = url.pathname.split('/').filter(Boolean)
      const hostname = url.hostname.replace('www.', '')

      if (hostname === 'github.com' && parts.length >= 2) {
        const base = `${parts[0]}/${parts[1]}`
        const last = parts[parts.length - 1]
        const num = /^\d+$/.test(last) && parts.length > 2 ? `#${last}` : ''
        label = `${base}${num}`
      } else {
        const slug = parts[parts.length - 1] || ''
        const short = slug.length > 32 ? slug.slice(0, 30) + '…' : slug
        label = short ? `${hostname}/${short}` : hostname
      }
    } catch {}
    refs.push({ href, label })
  }
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  sidebar={{ ...SIDEBAR, nav }}
  status={{ messages: STATUS_MESSAGES }}
>
  <div class="progress-bar" id="reading-progress" aria-hidden="true"></div>

  <div id="top"></div>
  <Breadcrumb
    crumbs={[
      { label: 'Index', href: '/' },
      { label: 'Posts', href: '/posts' },
      { label: post.data.title },
    ]}
  />

  <div class="post-layout">
    <div class="toc-col">
      {toc.length > 0 && (
        <nav class="toc" aria-label="On this page">
          <p class="toc__heading section-label">On this page</p>
          <ol class="toc__list">
            {toc.map((h, i) => (
              <li class="toc__item" style={`padding-inline-start: ${(h.depth - 2) * 0.75}rem`}>
                <a class="toc__link" href={`#${h.slug}`}>
                  {String(i + 1).padStart(2, '0')}. {h.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )}
      {refs.length > 0 && (
        <aside class="toc-refs" aria-label="References">
          <p class="toc-refs__heading section-label">References</p>
          <ol class="toc-refs__list">
            {refs.map((ref, i) => (
              <li class="toc-refs__item">
                <span class="toc-refs__num">{String(i + 1).padStart(2, '0')}.</span>
                <a class="toc-refs__link" href={ref.href} target="_blank" rel="noopener">{ref.label}</a>
              </li>
            ))}
          </ol>
        </aside>
      )}
    </div>

    <article class="post">
      <header class="post__header">
        <div class="post__meta meta-row">
          {post.data.ref && <span class="post__ref">REF: {post.data.ref}</span>}
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' }).toUpperCase()}
          </time>
          {post.data.readTime && <span>{post.data.readTime} MIN READ</span>}
        </div>
        <h1 class="post__title" transition:name={`post-title-${post.id}`}>{post.data.title}</h1>
      </header>

      {(toc.length > 0 || refs.length > 0) && (
        <details class="post-toc-dropdown">
          <summary class="post-toc-dropdown__summary">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 3H10M2 6H10M2 9H7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Contents
            <svg class="post-toc-dropdown__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <div class="post-toc-dropdown__body">
            {toc.length > 0 && (
              <nav aria-label="On this page">
                <p class="post-toc-dropdown__label section-label">On this page</p>
                <ol class="toc__list">
                  {toc.map((h, i) => (
                    <li style={`padding-inline-start: ${(h.depth - 2) * 0.75}rem`}>
                      <a class="toc__link" href={`#${h.slug}`}>
                        {String(i + 1).padStart(2, '0')}. {h.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            )}
            {refs.length > 0 && (
              <div>
                <p class="post-toc-dropdown__label section-label">References</p>
                <ol class="toc-refs__list">
                  {refs.map((ref, i) => (
                    <li class="toc-refs__item">
                      <span class="toc-refs__num">{String(i + 1).padStart(2, '0')}.</span>
                      <a class="toc-refs__link" href={ref.href} target="_blank" rel="noopener">{ref.label}</a>
                    </li>
                  ))}
                </ol>
              </div>
            )}
          </div>
        </details>
      )}

      <div class="post__body">
        <Content />
      </div>

      <PostEnding client:visible />
    </article>
  </div>

  <a
    class="back-to-top"
    href="#top"
    aria-label="Back to top"
  >
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M7 11V3M3.5 6.5L7 3L10.5 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</BaseLayout>

<style>
  :global(.breadcrumb) {
    margin-inline-start: calc(12rem + var(--s3));
  }

  .post-layout {
    display: flex;
    gap: var(--s3);
    align-items: flex-start;
    padding-block-start: var(--s1);
  }

  /* ToC column — sticky, holds both ToC and refs */
  .toc-col {
    flex-shrink: 0;
    inline-size: 12rem;
    position: sticky;
    inset-block-start: calc(var(--statusbar-height) + var(--s2));
    align-self: flex-start;
    display: flex;
    flex-direction: column;
    gap: var(--s2);
    min-block-size: calc(100vh - var(--statusbar-height) - var(--s2) * 2);
  }

  .toc {
    flex-shrink: 0;
  }

  .toc-refs {
    margin-block-start: auto;
    border-block-start: var(--border-thin) solid var(--color-border);
    padding-block-start: var(--s1);
  }

  .toc-refs__heading {
    /* base styles via .section-label */
    margin-block-end: 0.5rem;
  }

  .toc-refs__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .toc-refs__item {
    display: flex;
    gap: 0.35rem;
    align-items: baseline;
  }

  .toc-refs__num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .toc-refs__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    line-height: 1.4;
    word-break: break-all;
    transition: color 0.1s;
  }

  .toc-refs__link:hover {
    color: var(--color-brand);
  }

  /* Post */
  .post {
    flex: 1;
    max-inline-size: 44rem;
    min-inline-size: 0;
  }

  .post__meta {
    /* base styles via .meta-row */
    margin-block-end: var(--s1);
  }

  .post__ref {
    background: transparent;
    color: var(--color-accent);
    padding: 0;
    border-radius: var(--border-radius-sm);
    font-size: var(--text-2xs);
    font-weight: 600;
  }

  .post__title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw + 1rem, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-block-end: var(--s2);
  }

  /* Mobile ToC dropdown — hidden on desktop */
  .post-toc-dropdown {
    display: none;
  }

  .back-to-top {
    display: flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    inset-block-end: var(--s2);
    inset-inline-end: var(--s2);
    z-index: 12;
    inline-size: 2.5rem;
    block-size: 2.5rem;
    background: var(--color-chrome);
    color: var(--color-chrome-text);
    border: var(--border-thin) solid var(--color-border);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 8px hsl(0 0% 0% / 0.15);
    transition: opacity 0.15s ease, transform 0.1s ease;
  }

  .back-to-top:hover {
    opacity: 0.8;
    transform: translateY(-2px);
  }

  .back-to-top:active {
    transform: scale(0.94);
  }

  /* Prose styles for rendered markdown */
  .post__body :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-block: var(--s2) var(--s-1);
  }

  .post__body :global(h3) {
    font-size: 1.05rem;
    font-weight: 700;
    margin-block: var(--s1) var(--s-1);
  }

  .post__body :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-inline-size: 60ch;
    margin-block-end: var(--s1);
  }

  .post__body :global(a) {
    color: var(--color-brand);
    text-underline-offset: 0.2em;
  }

  .post__body :global(ul),
  .post__body :global(ol) {
    padding-inline-start: var(--s1);
    margin-block-end: var(--s1);
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .post__body :global(li) {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  /* Prevent code blocks from causing page-level horizontal scroll */
  .post__body {
    overflow-x: hidden;
  }

  .post__body :global(pre),
  .post__body :global(pre.astro-code) {
    max-inline-size: 100%;
    overflow-x: auto;
  }

  @media (max-width: 48em) {
    :global(.breadcrumb) {
      margin-inline-start: 0;
    }

    .post-layout {
      flex-direction: column;
      gap: var(--s2);
    }

    .toc-col {
      display: none;
    }

    /* Mobile ToC dropdown */
    .post-toc-dropdown {
      display: block;
      border: var(--border-thin) solid var(--color-border);
      border-radius: var(--border-radius);
      margin-block-end: var(--s2);
      overflow: hidden;
    }

    .post-toc-dropdown__summary {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding-block: 0.625rem;
      padding-inline: var(--s1);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--color-text-muted);
      cursor: pointer;
      list-style: none;
      user-select: none;
    }

    /* Remove default marker */
    .post-toc-dropdown__summary::-webkit-details-marker { display: none; }

    .post-toc-dropdown__chevron {
      margin-inline-start: auto;
      transition: transform 0.2s ease;
      flex-shrink: 0;
    }

    .post-toc-dropdown[open] .post-toc-dropdown__chevron {
      transform: rotate(180deg);
    }

    .post-toc-dropdown__body {
      display: flex;
      flex-direction: column;
      gap: var(--s1);
      padding: var(--s1);
      border-block-start: var(--border-thin) solid var(--color-border);
    }

    .post-toc-dropdown__label {
      /* base styles via .section-label */
      margin-block-end: 0.375rem;
    }

    .post__body :global(p),
    .post__body :global(li) {
      font-size: 0.9375rem;
      line-height: 1.65;
    }

    .post__body :global(h2) {
      font-size: 1.125rem;
    }

    .post__body :global(h3) {
      font-size: 1rem;
    }
  }
</style>

<script lang="ts">
  import { initReadingProgress } from '../../lib/reading-progress'
  import { initTocObserver } from '../../lib/toc-observer'

  function initPost(): void {
    initReadingProgress('reading-progress', '.post')
    initTocObserver('.post__body h2, .post__body h3')
  }

  document.addEventListener('astro:page-load', initPost)
</script>
