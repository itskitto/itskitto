---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import AvailabilityBadge from "../components/AvailabilityBadge.astro";
import { SITE_TITLE, SIDEBAR, STATUS_MESSAGES } from "../config";
import { getNav } from "../lib/nav";

const posts = await getCollection("posts", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);

const recentPosts = [...posts]
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 5);

const nav = await getNav();
---

<BaseLayout
  title={`${SITE_TITLE} - Software Engineer`}
  sidebar={{
    ...SIDEBAR,
    nav,
  }}
  status={{ messages: STATUS_MESSAGES }}
>
  <Breadcrumb crumbs={[{ label: "Index" }, { label: "Home" }]} />

  <div class="home">
    {SIDEBAR.availability && <AvailabilityBadge label={SIDEBAR.availability} />}
    <h1 class="home__headline">
      Crafting software that helps people get back to the work that matters.
    </h1>
    <p class="home__sub">
      I work with product teams and small businesses; from the interface people
      click to the background systems that have to keep running.
    </p>

    <div class="home__actions">
      <a class="btn btn--primary btn--lg" href="/posts">Read the posts</a>
      <a class="btn btn--secondary btn--lg" href="/contact">Get in touch</a>
    </div>

    <section class="repo">
      <p class="repo__heading">INFO_REPO</p>

      <div class="repo-c__body">
        <div class="repo-c__block">
          <p class="repo-c__key">GITHUB</p>
          <a
            class="repo-c__val"
            href="https://github.com/itskitto"
            target="_blank"
            rel="noopener">github.com/itskitto</a
          >
        </div>
        <div class="repo-c__block">
          <p class="repo-c__key">TWITTER</p>
          <a
            class="repo-c__val"
            href="https://x.com/itskitto_dev"
            target="_blank"
            rel="noopener">x.com/itskitto_dev</a
          >
        </div>
        <div class="repo-c__block">
          <p class="repo-c__key">LINKEDIN</p>
          <a
            class="repo-c__val"
            href="https://linkedin.com/in/nicholaskhrangtong"
            target="_blank"
            rel="noopener">linkedin.com/in/nicholaskhrangtong</a
          >
        </div>
        <div class="repo-c__block">
          <p class="repo-c__key">RESUME</p>
          <a class="repo-c__val" href="/resume.pdf" download
            >Khrangtong2026Res.pdf ↓</a
          >
        </div>
        <div class="repo-c__divider"></div>
        <div class="repo-c__block">
          <p class="repo-c__key">PROJECT_01</p>
          <div>
            <p class="repo-c__val">Greenline Landscaping</p>
            <p class="repo-c__meta">
              Business management platform · React / FastAPI / PostgreSQL /
              Temporal
            </p>
          </div>
        </div>
        <div class="repo-c__block">
          <p class="repo-c__key">PROJECT_02</p>
          <div>
            <p class="repo-c__val">Sandbox</p>
            <p class="repo-c__meta">
              FigJam-style sandbox with my code snippets and project POCs ·
              React / TypeScript / Supabase
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="home__recent">
      <div class="home__recent-header">
        <p class="home__section-label">Recent Posts</p>
        <a class="home__view-all" href="/posts">View all</a>
      </div>
      <ul class="home__post-list">
        {
          recentPosts.map((post) => (
            <li class="home__post-row">
              <time
                class="home__post-date"
                datetime={post.data.pubDate.toISOString()}
              >
                {post.data.pubDate.toLocaleDateString("en-US", {
                  month: "short",
                  day: "2-digit",
                  year: "numeric",
                })}
              </time>
              <a class="home__post-title" href={`/posts/${post.id}`}>
                {post.data.title}
              </a>
              {post.data.ref && (
                <span class="home__post-ref">{post.data.ref}</span>
              )}
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    max-inline-size: 48rem;
    padding-block-start: var(--s2);
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .home > * {
      animation: fade-up 0.55s var(--ease-out-quart) both;
    }

    .home > *:nth-child(2) { animation-delay: 55ms; }
    .home > *:nth-child(3) { animation-delay: 110ms; }
    .home > *:nth-child(4) { animation-delay: 160ms; }
    .home > *:nth-child(5) { animation-delay: 215ms; }
    .home > *:nth-child(6) { animation-delay: 270ms; }
  }

  /* ── Shared repo section chrome ── */
  .repo {
    margin-block-start: var(--s2);
    padding-block-start: var(--s2);
    border-block-start: var(--border-thin) solid var(--color-border);
  }

  .repo__heading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-block-end: var(--s1);
  }

  /* ── Info Repo — mono terminal rows ── */
  .repo-c__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .repo-c__block {
    display: flex;
    gap: var(--s1);
    align-items: flex-start;
  }

  .repo-c__key {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    inline-size: 8rem;
    flex-shrink: 0;
    padding-block-start: 0.15rem;
  }

  .repo-c__val {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.1s;
    display: block;
  }

  .repo-c__val:hover {
    color: var(--color-brand);
  }

  .repo-c__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-block-start: 0.2rem;
  }

  .repo-c__divider {
    block-size: var(--border-thin);
    background: var(--color-border);
    margin-block: 0.25rem;
  }

  .home__headline {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw + 1rem, 3rem);
    font-weight: 400;
    line-height: 1.15;
    margin-block-start: var(--s1);
    letter-spacing: -0.01em;
    margin-block-end: var(--s1);
  }

  .home__sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-inline-size: 48ch;
    margin-block-end: var(--s2);
  }

  .home__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block-end: var(--s3);
  }

  .home__section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .home__recent {
    margin-block-start: var(--s2);
    padding-block-start: var(--s2);
    border-block-start: var(--border-thin) solid var(--color-border);
  }

  .home__recent-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block-end: 0.5rem;
    border-block-end: var(--border-thin) solid var(--color-border);
    margin-block-end: 0.25rem;
  }

  .home__view-all {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand);
    text-decoration: none;
  }

  .home__post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .home__post-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding-block: 0.625rem;
    border-block-end: var(--border-thin) solid var(--color-border);
  }

  .home__post-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .home__post-title {
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.1s;
  }

  .home__post-title:hover {
    color: var(--color-brand);
  }

  .home__post-ref {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-inline-start: auto;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 48em) {
    .home__post-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.15rem;
    }

    .home__post-ref {
      margin-inline-start: 0;
    }
  }
</style>
